{
  "name": "logbook",
  "version": "1.0.0",
  "author": "Scott Vandehey",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "run-s lint:js lint:css lint:prettier",
    "lint:check": "run-s lint:*:check",
    "lint:js": "eslint . --fix",
    "lint:js:check": "eslint .",
    "lint:css": "stylelint --fix '**/*.{css,vue}'",
    "lint:css:check": "stylelint '**/*.{css,vue}'",
    "lint:prettier": "prettier . --write",
    "lint:prettier:check": "prettier . --check",
    "type-check": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "run-s lint:check type-check test",
    "firebase": "firebase",
    "deploy:rules:dev": "firebase deploy --only firestore:rules --project dev --config firebase.dev.json",
    "deploy:rules:prod": "firebase deploy --only firestore:rules --project prod --config firebase.json",
    "deploy:indexes:dev": "firebase deploy --only firestore:indexes --project dev --config firebase.dev.json",
    "deploy:indexes:prod": "firebase deploy --only firestore:indexes --project prod --config firebase.json"
  },
  "dependencies": {
    "firebase": "12.15.0",
    "nuxt": "4.4.8",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nuxt/test-utils": "4.0.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/vue": "8.1.0",
    "@typescript-eslint/parser": "8.62.0",
    "@vitest/eslint-plugin": "1.6.20",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-testing-library": "7.16.2",
    "eslint-plugin-vue": "10.9.2",
    "firebase-tools": "15.22.1",
    "jsdom": "29.1.1",
    "npm-run-all2": "9.0.2",
    "prettier": "3.8.4",
    "stylelint": "17.11.1",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-spaceninja": "17.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.5"
  }
}
