{
	"name": "logbook",
	"version": "1.0.0",
	"author": "Scott Vandehey",
	"license": "MIT",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"lint": "run-s lint:js lint:css lint:prettier",
		"lint:check": "run-s lint:*:check",
		"lint:js": "eslint . --fix",
		"lint:js:check": "eslint .",
		"lint:css": "stylelint --fix '**/*.{css,vue}'",
		"lint:css:check": "stylelint '**/*.{css,vue}'",
		"lint:prettier": "prettier . --write",
		"lint:prettier:check": "prettier . --check",
		"type-check": "nuxt typecheck",
		"test": "vitest run",
		"test:watch": "vitest",
		"generate:sample": "node scripts/generate-sample.js",
		"sync:goodreads": "tsx scripts/sync-goodreads.ts",
		"validate": "run-s lint:check type-check test",
		"firebase": "firebase",
		"deploy:rules:dev": "firebase deploy --only firestore:rules --project dev --config firebase.dev.json",
		"deploy:rules:prod": "firebase deploy --only firestore:rules --project prod --config firebase.json",
		"deploy:indexes:dev": "firebase deploy --only firestore:indexes --project dev --config firebase.dev.json",
		"deploy:indexes:prod": "firebase deploy --only firestore:indexes --project prod --config firebase.json"
	},
	"dependencies": {
		"@vueuse/core": "14.3.0",
		"@vueuse/router": "14.3.0",
		"fast-xml-parser": "^5.10.1",
		"firebase": "12.16.0",
		"firebase-admin": "^14.2.0",
		"jszip": "3.10.1",
		"markdown-it": "14.3.0",
		"nuxt": "4.5.0",
		"vue": "3.5.40",
		"vue-router": "5.2.0"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@nuxt/test-utils": "4.0.3",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/vue": "8.1.0",
		"@types/markdown-it": "14.1.2",
		"@typescript-eslint/parser": "8.64.0",
		"@vitest/eslint-plugin": "1.6.23",
		"@vue/test-utils": "2.4.11",
		"dotenv": "^17.4.2",
		"eslint": "10.7.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-testing-library": "7.16.2",
		"eslint-plugin-vue": "10.10.0",
		"firebase-tools": "15.24.0",
		"jsdom": "29.1.1",
		"npm-run-all2": "9.0.2",
		"prettier": "3.9.5",
		"stylelint": "17.14.1",
		"stylelint-config-recommended-vue": "1.6.1",
		"stylelint-config-spaceninja": "17.0.0",
		"tsx": "^4.23.1",
		"typescript": "6.0.3",
		"vitest": "4.1.10",
		"vue-eslint-parser": "10.4.1",
		"vue-tsc": "3.3.7"
	},
	"overrides": {
		"@vue/server-renderer": "$vue"
	}
}
