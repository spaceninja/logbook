# Goodreads RSS sync (scripts/sync-goodreads.ts). The RSS key is a secret — get it
# from a Goodreads shelf RSS URL. FIREBASE_SERVICE_ACCOUNT is the raw JSON of a
# service-account key (dev project for local runs); the Admin SDK bypasses rules.
GOODREADS_USER_ID=XXX
GOODREADS_RSS_KEY=XXX
FIREBASE_SERVICE_ACCOUNT=XXX
