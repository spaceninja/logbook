# Dummy Firebase config for the test runtime. Tests execute inside the Nuxt
# runtime (see vitest.config.ts), so firebase.client.ts runs and calls getAuth().
# With an empty apiKey that throws auth/invalid-api-key and floods test output;
# a syntactically valid (but fake) key initializes quietly without any network.
# @nuxt/test-utils loads this file via applyEnv (prefix NUXT_). Safe to commit:
# no real credentials, and CI needs it too.
NUXT_PUBLIC_FIREBASE_API_KEY=test-api-key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=test.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=test-project
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=test-project.appspot.com
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NUXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NUXT_PUBLIC_OWNER_UID=test-owner-uid
