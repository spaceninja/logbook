rules_version = '2';

// DEV rules. Public read; writes restricted to the owner (the seed buttons and
// add/edit/delete require the owner to be signed in). Deploy ONLY to the
// logbook-dev project. The UID is this project's owner UID (per-project).
service cloud.firestore {
  match /databases/{database}/documents {
    match /items/{id} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == 'eRrTVzUxwUNOh3a7DbJa4F0uWeC3';
    }
  }
}
